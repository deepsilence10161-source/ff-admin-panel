{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "globals": {
    "firebase": "readonly",
    "rtdb": "readonly",
    "auth": "readonly",
    "db": "readonly",
    "adminDb": "readonly",
    "window": "writable",
    "document": "readonly",
    "showToast": "readonly",
    "setLoading": "readonly",
    "allTournaments": "writable",
    "allJoinRequests": "writable",
    "usersCache": "writable",
    "usersSnapshot": "writable"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "vars": "all",
        "args": "after-used"
      }
    ],
    "no-undef": "warn",
    "no-console": "off",
    "eqeqeq": [
      "error",
      "always"
    ],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "no-inner-declarations": "warn",
    "no-duplicate-case": "error"
  }
}